@model ReportsDashboardDto
@{
    ViewData["Title"] = "Reports";
}

<h2 class="mb-3">Reports and Statistics</h2>

<form method="get" class="row g-3 mb-4 p-3 bg-light rounded border">
    <div class="col-md-4">
        <label class="form-label">From</label>
        <input type="date" name="fromDate" class="form-control" value="@Model.FromDate.ToString("yyyy-MM-dd")" />
    </div>
    <div class="col-md-4">
        <label class="form-label">To</label>
        <input type="date" name="toDate" class="form-control" value="@Model.ToDate.ToString("yyyy-MM-dd")" />
    </div>
    <div class="col-md-4 d-flex align-items-end">
        <button class="btn btn-dark" type="submit">Generate</button>
    </div>
</form>

<div class="alert alert-primary">
    <strong>Total revenue for period:</strong> €@Model.TotalRevenue.ToString("F2")
</div>

<h4>Sales by Event</h4>
@if (!Model.Events.Any())
{
    <div class="alert alert-info">No ticket sales were found for the selected period.</div>
}
else
{
    <div class="table-responsive mb-4">
        <table class="table table-striped table-bordered align-middle">
            <thead class="table-dark">
                <tr>
                    <th>Event</th>
                    <th>Category</th>
                    <th>Sold Seats</th>
                    <th>Capacity</th>
                    <th>Sold %</th>
                    <th>Revenue</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Events)
                {
                    <tr>
                        <td>@item.EventTitle</td>
                        <td>@item.CategoryName</td>
                        <td>@item.SoldSeats</td>
                        <td>@item.Capacity</td>
                        <td>@item.SoldPercentage.ToString("F2")%</td>
                        <td>€@item.Revenue.ToString("F2")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

<h4>Statistics by Category</h4>
@if (!Model.Categories.Any())
{
    <div class="alert alert-info">No category statistics were found for the selected period.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-bordered align-middle">
            <thead class="table-dark">
                <tr>
                    <th>Category</th>
                    <th>Total Sold Seats</th>
                    <th>Revenue</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Categories)
                {
                    <tr>
                        <td>@item.CategoryName</td>
                        <td>@item.TotalSoldSeats</td>
                        <td>€@item.Revenue.ToString("F2")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
