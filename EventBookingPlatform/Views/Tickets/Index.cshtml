@model List<TicketListDto>
@{
    ViewData["Title"] = "All Tickets";
}

<h2 class="mb-3">All Tickets</h2>

<div class="table-responsive">
    <table class="table table-striped table-bordered align-middle">
        <thead class="table-dark">
            <tr>
                <th>Event</th>
                <th>Buyer</th>
                <th>Event Date</th>
                <th>Purchased</th>
                <th>Quantity</th>
                <th>Total</th>
                <th>Status</th>
                <th class="text-center">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.EventTitle</td>
                    <td>@item.BuyerName<br /><small>@item.BuyerEmail</small></td>
                    <td>@item.EventDate.ToString("dd MMM yyyy HH:mm")</td>
                    <td>@item.PurchasedAt.ToString("dd MMM yyyy HH:mm")</td>
                    <td>@item.Quantity</td>
                    <td>€@item.TotalPrice.ToString("F2")</td>
                    <td>@item.Status</td>
                    <td class="text-center">
                        <a class="btn btn-sm btn-outline-secondary" asp-action="Details" asp-route-id="@item.Id">Details</a>
                        <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@item.Id">Edit</a>
                        @if (User.IsInRole("Admin"))
                        {
                            <a class="btn btn-sm btn-outline-danger" asp-action="Delete" asp-route-id="@item.Id">Delete</a>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
