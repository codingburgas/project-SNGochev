@model TicketListDto
@{
    ViewData["Title"] = "Delete Ticket";
}

<div class="card border-danger shadow-sm">
    <div class="card-body">
        <h2>Delete Ticket</h2>
        <p>Are you sure you want to delete ticket <strong>#@Model.Id</strong> for <strong>@Model.EventTitle</strong>?</p>
        <form method="post">
            <button class="btn btn-danger" type="submit">Delete</button>
            <a class="btn btn-secondary" asp-action="Index">Cancel</a>
        </form>
    </div>
</div>
