@model TicketPurchaseDto
@{
    ViewData["Title"] = "Purchase Tickets";
    var eventInfo = ViewBag.Event as EventDetailsDto;
}

<div class="row">
    <div class="col-lg-7">
        <div class="card shadow-sm mb-3">
            <div class="card-body">
                <h2>Purchase Tickets</h2>
                @if (eventInfo is not null)
                {
                    <p class="mb-1"><strong>Event:</strong> @eventInfo.Title</p>
                    <p class="mb-1"><strong>Date:</strong> @eventInfo.EventDate.ToString("dd MMM yyyy HH:mm")</p>
                    <p class="mb-1"><strong>Venue:</strong> @eventInfo.Venue</p>
                    <p class="mb-1"><strong>Price per ticket:</strong> €@eventInfo.TicketPrice.ToString("F2")</p>
                    <p class="mb-0"><strong>Available seats:</strong> @eventInfo.AvailableSeats</p>
                }
            </div>
        </div>

        <form method="post" class="card shadow-sm p-4">
            <input asp-for="EventId" type="hidden" />
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="Quantity" class="form-label"></label>
                <input asp-for="Quantity" class="form-control" />
                <span asp-validation-for="Quantity" class="text-danger"></span>
            </div>

            <div class="d-flex gap-2">
                <button class="btn btn-success" type="submit">Confirm Purchase</button>
                <a class="btn btn-secondary" asp-controller="Events" asp-action="Details" asp-route-id="@Model.EventId">Back</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
