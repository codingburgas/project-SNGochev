@model List<EventListDto>
@{
    ViewData["Title"] = "Events";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Events</h2>
    @if (User.IsInRole("Admin") || User.IsInRole("Organizer"))
    {
        <a class="btn btn-primary" asp-action="Create">Create Event</a>
    }
</div>

<form method="get" class="row g-3 mb-4 p-3 bg-light rounded border">
    <div class="col-md-4">
        <label class="form-label">From date</label>
        <input type="date" name="fromDate" class="form-control" value="@ViewBag.FromDate" />
    </div>
    <div class="col-md-4">
        <label class="form-label">Category</label>
        <select name="categoryId" class="form-select" asp-items="ViewBag.Categories">
            <option value="">All categories</option>
        </select>
    </div>
    <div class="col-md-4 d-flex align-items-end gap-2">
        <button class="btn btn-dark" type="submit">Filter</button>
        <a class="btn btn-outline-secondary" asp-action="Index">Clear</a>
    </div>
</form>

@if (!Model.Any())
{
    <div class="alert alert-info">No events match the selected filters.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-bordered align-middle">
            <thead class="table-dark">
                <tr>
                    <th>Title</th>
                    <th>Category</th>
                    <th>Date</th>
                    <th>Venue</th>
                    <th>Price</th>
                    <th>Available Seats</th>
                    <th class="text-center">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Title</td>
                        <td>@item.CategoryName</td>
                        <td>@item.EventDate.ToString("dd MMM yyyy HH:mm")</td>
                        <td>@item.Venue</td>
                        <td>€@item.TicketPrice.ToString("F2")</td>
                        <td>@item.AvailableSeats / @item.Capacity</td>
                        <td class="text-center">
                            <a class="btn btn-sm btn-outline-secondary" asp-action="Details" asp-route-id="@item.Id">Details</a>
                            @if (User.IsInRole("Admin") || User.IsInRole("Organizer"))
                            {
                                <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@item.Id">Edit</a>
                            }
                            @if (User.Identity?.IsAuthenticated == true && item.AvailableSeats > 0)
                            {
                                <a class="btn btn-sm btn-success" asp-controller="Tickets" asp-action="Purchase" asp-route-eventId="@item.Id">Buy</a>
                            }
                            @if (User.IsInRole("Admin"))
                            {
                                <a class="btn btn-sm btn-outline-danger" asp-action="Delete" asp-route-id="@item.Id">Delete</a>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
