@model EventDetailsDto
@{
    ViewData["Title"] = "Event Details";
}

<div class="card shadow-sm">
    <div class="card-body">
        <div class="d-flex justify-content-between flex-wrap gap-3">
            <div>
                <span class="badge bg-primary mb-2">@Model.CategoryName</span>
                <h2>@Model.Title</h2>
                <p class="text-muted">@Model.Description</p>
            </div>
            <div class="text-md-end">
                <h4 class="text-success">€@Model.TicketPrice.ToString("F2")</h4>
                <p class="mb-0">Sold: @Model.SoldSeats / @Model.Capacity</p>
                <p class="mb-0">Available: @Model.AvailableSeats</p>
                <p class="mb-0">Sold percentage: @Model.SoldPercentage.ToString("F2")%</p>
            </div>
        </div>

        <hr />

        <div class="row">
            <div class="col-md-6">
                <p><strong>Date:</strong> @Model.EventDate.ToString("dd MMM yyyy HH:mm")</p>
                <p><strong>Venue:</strong> @Model.Venue</p>
            </div>
        </div>

        <div class="d-flex gap-2">
            <a class="btn btn-secondary" asp-action="Index">Back</a>
            @if (User.Identity?.IsAuthenticated == true && Model.AvailableSeats > 0)
            {
                <a class="btn btn-success" asp-controller="Tickets" asp-action="Purchase" asp-route-eventId="@Model.Id">Buy Tickets</a>
            }
            @if (User.IsInRole("Admin") || User.IsInRole("Organizer"))
            {
                <a class="btn btn-primary" asp-action="Edit" asp-route-id="@Model.Id">Edit</a>
            }
        </div>
    </div>
</div>
